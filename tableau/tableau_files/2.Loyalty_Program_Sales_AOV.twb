  <worksheets>
    <worksheet name='Loyalty program: AOV'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#59a14f' fontname='Tableau Bold' fontsize='18'> ⬤ LOYALTY MEMBER  </run>
            <run>Æ&#10;</run>
            <run fontcolor='#59a14f' fontname='Tableau Bold' fontsize='18'>Æ </run>
            <run fontcolor='#898989' fontname='Tableau Bold' fontsize='18'>⬤ NON-LOYALTY MEMBER</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='olist_orders_dataset+' name='federated.0cwjwje1jn7uae1gr4ndk1oavgf0' />
          </datasources>
          <datasource-dependencies datasource='federated.0cwjwje1jn7uae1gr4ndk1oavgf0'>
            <column caption='Customer Order Count' datatype='integer' name='[Calculation_0279328517300224]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [customer_unique_id] : &#13;&#10;    COUNTD(IF [order_status] = &apos;delivered&apos; THEN [order_id] END)&#13;&#10;}' />
            </column>
            <column caption='Loyalty Status' datatype='string' name='[Calculation_0279328517754881]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0279328517300224] &gt; 1 THEN &quot;Loyal&quot;&#13;&#10;ELSE &quot;Non-Loyal&quot;&#13;&#10;END' />
            </column>
            <column caption='AOV' datatype='real' name='[Calculation_1878017322045453]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([freight_value] + [price]) / COUNTD([order_id])' />
            </column>
            <column caption='Customer Unique Id' datatype='string' name='[customer_unique_id]' role='dimension' type='nominal' />
            <column caption='Freight Value' datatype='real' name='[freight_value]' role='measure' type='quantitative' />
            <column-instance column='[order_purchase_timestamp]' derivation='Month' name='[mn:order_purchase_timestamp:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0279328517754881]' derivation='None' name='[none:Calculation_0279328517754881:nk]' pivot='key' type='nominal' />
            <column-instance column='[order_status]' derivation='None' name='[none:order_status:nk]' pivot='key' type='nominal' />
            <column caption='Order Id' datatype='string' name='[order_id]' role='dimension' type='nominal' />
            <column caption='Order Purchase Timestamp' datatype='datetime' name='[order_purchase_timestamp]' role='dimension' type='ordinal' />
            <column caption='Order Status' datatype='string' name='[order_status]' role='dimension' type='nominal' />
            <column caption='Price' datatype='real' name='[price]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1878017322045453]' derivation='User' name='[usr:Calculation_1878017322045453:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0cwjwje1jn7uae1gr4ndk1oavgf0].[none:order_status:nk]'>
            <groupfilter function='member' level='[none:order_status:nk]' member='&quot;delivered&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.0cwjwje1jn7uae1gr4ndk1oavgf0].[none:order_status:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
