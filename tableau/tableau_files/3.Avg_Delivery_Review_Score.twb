      <column caption='Customer Order Count' datatype='integer' name='[Calculation_0279328517300224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_unique_id] : &#13;&#10;    COUNTD(IF [order_status] = &apos;delivered&apos; THEN [order_id] END)&#13;&#10;}' />
      </column>
      <column caption='Loyalty Status' datatype='string' name='[Calculation_0279328517754881]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0279328517300224] &gt; 1 THEN &quot;Loyal&quot;&#13;&#10;ELSE &quot;Non-Loyal&quot;&#13;&#10;END' />
      </column>
      <column caption='Order Month' datatype='integer' name='[Calculation_0279328537128965]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MONTH([order_purchase_timestamp])' />
      </column>
      <column caption='max_total_sales' datatype='real' default-format='c#,##0,K;(#,##0,K)' name='[Calculation_0924190021619712]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Calculation_1257891486924800]) = WINDOW_MAX(SUM([Calculation_1257891486924800]))&#13;&#10;THEN SUM([Calculation_1257891486924800])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='year_order' datatype='integer' name='[Calculation_0924190029873153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([order_purchase_timestamp])' />
      </column>
      <column caption='Total Sales (BANS)' datatype='real' name='[Calculation_0924190035562498]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM([Calculation_1257891486924800]) }' />
      </column>
      <column caption='Total Sales' datatype='real' name='[Calculation_1257891486924800]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[freight_value] + [price]' />
      </column>
      <column caption='valid_year' datatype='boolean' name='[Calculation_1878017297948678]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([order_purchase_timestamp]) = 2018 &#13;&#10;AND MONTH([order_purchase_timestamp]) &gt; 8&#13;&#10;THEN FALSE&#13;&#10;ELSE TRUE&#13;&#10;END' />
