              <calculation class='tableau' formula='IF YEAR([order_purchase_timestamp]) = 2018 &#13;&#10;AND MONTH([order_purchase_timestamp]) &gt; 8&#13;&#10;THEN FALSE&#13;&#10;ELSE TRUE&#13;&#10;END' />
            </column>
            <column caption='Sales Growth %' datatype='real' name='[Calculation_1878017335865358]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([freight_value]+[price]) - &#13;&#10;LOOKUP(SUM([freight_value]+[price]), -1))&#13;&#10;/ LOOKUP(SUM([freight_value]+[price]), -1)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='AOV Growth %' datatype='real' name='[Calculation_1878017336848400]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([freight_value] + [price]) / COUNTD([order_id]) - &#13;&#10;LOOKUP(SUM([freight_value] + [price]) / COUNTD([order_id]), -1)) &#13;&#10;/ LOOKUP(SUM([freight_value] + [price]) / COUNTD([order_id]), -1)'>
